      "parameters": {
        "jsCode": "// 1. Change 'output' to the correct input variable, which is now accessing the nested 'output' key\nlet rawText = $json.output.complete_resume_text; \n\n// 2. Safely handle if the text is null or undefined before replacing\nif (rawText) {\n    // 3. This converts the escaped sequence '\\n' into a true newline character.\n    let cleanText = rawText.replace(/\\\\n/g, '\\n')\n                           .replace(/\\\\\"/g, '\"'); // Also clean up escaped quotes\n\n    // 4. Output the clean string to the next node\n    return {\n      \"text_to_insert\": cleanText\n    };\n} else {\n    // If the data is missing, return an empty object or a message\n    return {\n      \"text_to_insert\": \"\"\n    };\n}"
      },
